# ---- Cyra Console · AWS Bedrock (server-side only) ----
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# The app runs fully WITHOUT these (committed cached fallback). Fill them in
# to make Screen 3 (grading) and Screen 4 (decision) genuinely LIVE.

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Bedrock model id for Amazon Nova Pro (multimodal).
# IMPORTANT: Nova on-demand needs the REGIONAL INFERENCE PROFILE id, not the bare
# model id. For us-east-1 (US regions) use the "us." prefix below. (EU: "eu.", APAC: "apac.")
# Using the bare "amazon.nova-pro-v1:0" throws "on-demand throughput isn't supported".
NOVA_MODEL_ID=us.amazon.nova-pro-v1:0

# Port the Express proxy listens on (Vite proxies /api here)
API_PORT=8787
